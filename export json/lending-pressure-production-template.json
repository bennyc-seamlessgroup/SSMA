{
  "_template": "Lending Pressure page production data handoff",
  "_pageRoute": "/monitor/[ticker]/lending-pressure",
  "_purpose": "Fill only market-changing values, derived display values, trend series, and editable commentary used by the Lending Pressure page. Static UI headings and labels are intentionally excluded.",
  "_uploadNote": "This is a reference template. In production, upload each object under targetFiles to the matching S3/import_data path, for example import_data/short/shares_available.json.",
  "_fieldGuide": {
    "currentDateFields": "Use ISO date strings in YYYY-MM-DD format.",
    "importedAt": "Use ISO datetime when the backend/import pipeline writes the file.",
    "derivedCardRule": "The page prefers derived card values when present for Shares Available, Utilization, and Borrow Fee. Populate valueDisplay, changeDisplay, changePercentDisplay, deltaDisplay, previousValue, and deltaCurrentValue so the frontend does not calculate KPI changes.",
    "pressureScoreFormula": "pressureScore = round(availabilityPressure * 0.25 + utilizationPressure * 0.30 + borrowFeePressure * 0.30 + borrowDemandScore * 0.15).",
    "availabilityPressureFormula": "100 if sharesAvailable <= 100000; 78 if <= 500000; 48 if <= 1500000; otherwise 12.",
    "utilizationPressureFormula": "min(100, max(0, latest(shortAvailabilityPct))). Current MVP uses shortAvailabilityPct from shares_available.json for utilization display.",
    "borrowFeePressureFormula": "min(100, max(0, borrow_fee.json data.current.costToBorrowAll)).",
    "onLoanPressureFormula": "100 if sharesOnLoan >= 1000000; 62 if >= 650000; 38 if >= 400000; otherwise 12.",
    "borrowDemandScoreFormula": "round(utilizationPressure * 0.42 + borrowFeePressure * 0.35 + availabilityPressure * 0.18 + 5 if onLoanShares > 0).",
    "levelFormula": "Extreme if score >= 81; High if >= 61; Moderate if >= 31; otherwise Low.",
    "sharesAvailableFormula": "change = latest(data).shortAvailabilityShares - previous(data).shortAvailabilityShares; changePercent = change / previous(data).shortAvailabilityShares * 100.",
    "utilizationFormula": "change = latest(data).shortAvailabilityPct - previous(data).shortAvailabilityPct; changePercent = change / previous(data).shortAvailabilityPct * 100.",
    "borrowFeeFormula": "change = current.costToBorrowAll - previous(all[].costToBorrowAll); changePercent = change / previous(all[].costToBorrowAll) * 100.",
    "onLoanFormula": "change = latest(data).sharesOnLoan - previous(data).sharesOnLoan; changePercent = change / previous(data).sharesOnLoan * 100. The current page can calculate this if supplied with the trend rows."
  },
