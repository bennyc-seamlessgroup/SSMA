{
  "_template": "Short Interest page production data handoff",
  "_pageRoute": "/monitor/[ticker]/short-interest",
  "_purpose": "Fill only market-changing values, derived display values, chart series, and editable commentary used by the Short Interest page. Static UI headings and labels are intentionally excluded.",
  "_uploadNote": "This is a reference template. In production, upload each object under targetFiles to the matching S3/import_data path, for example import_data/short/short_interest.json.",
  "_fieldGuide": {
    "currentDateFields": "Use ISO date strings in YYYY-MM-DD format.",
    "importedAt": "Use ISO datetime when the backend/import pipeline writes the file.",
    "derivedCardRule": "The page prefers derived card values when present. Populate valueDisplay, changeDisplay, changePercentDisplay, deltaDisplay, previousValue, and deltaCurrentValue so the frontend does not calculate KPI changes.",
    "shortInterestCardFormula": "change = latest(finraHistory).currentShortPositionQuantity - latest(finraHistory).previousShortPositionQuantity; changePercent = change / latest(finraHistory).previousShortPositionQuantity * 100.",
    "shortInterestPercentFloatFormula": "change = current.shortInterestPcFreeFloat * shortInterest.changePercent / 100; changePercent = shortInterest.changePercent.",
    "daysToCoverFormula": "change = latest(finraHistory).daysToCoverQuantity - previous(finraHistory).daysToCoverQuantity; changePercent = change / previous(finraHistory).daysToCoverQuantity * 100.",
    "borrowFeeFormula": "change = current.costToBorrowAll - previous(all[].costToBorrowAll); changePercent = change / previous(all[].costToBorrowAll) * 100.",
    "sharesAvailableFormula": "change = latest(data).shortAvailabilityShares - previous(data).shortAvailabilityShares; changePercent = change / previous(data).shortAvailabilityShares * 100.",
    "utilizationFormula": "change = latest(data).shortAvailabilityPct - previous(data).shortAvailabilityPct; changePercent = change / previous(data).shortAvailabilityPct * 100.",
    "shortScoreFormula": "value = round(latest(data).score); change = value - previous(data).score; changePercent = change / previous(data).score * 100.",
    "shortScoreLevelFormula": "Extreme if score >= 80; High if >= 65; Moderate if >= 40; otherwise Low."
  },
